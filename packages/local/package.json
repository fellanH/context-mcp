{
  "name": "context-vault",
  "version": "3.4.2",
  "type": "module",
  "description": "Persistent memory for AI agents — saves and searches knowledge across sessions",
  "bin": {
    "context-vault": "bin/cli.js",
    "context-mcp": "bin/cli.js",
    "memory": "bin/cli.js"
  },
  "main": "dist/server.js",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./cli": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/server.ts",
    "postinstall": "node scripts/postinstall.js",
    "prepack": "node scripts/prepack.js"
  },
  "files": [
    "assets/",
    "bin/",
    "dist/",
    "src/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "author": "Felix Hellstrom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fellanH/context-vault.git"
  },
  "homepage": "https://github.com/fellanH/context-vault",
  "bugs": {
    "url": "https://github.com/fellanH/context-vault/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "knowledge-base",
    "knowledge-management",
    "vault",
    "rag",
    "sqlite",
    "embeddings",
    "claude",
    "cursor",
    "cline",
    "windsurf"
  ],
  "bundledDependencies": [
    "@context-vault/core"
  ],
  "dependencies": {
    "@context-vault/core": "^3.4.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "adm-zip": "^0.5.16",
    "sqlite-vec": "^0.1.0"
  },
  "bundleDependencies": [
    "@context-vault/core"
  ]
}
